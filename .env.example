# Nextcloud base URL — no trailing slash
NC_URL=https://cloud.example.com

# Nextcloud username
NC_USER=your-username

# App password — create one under Settings → Security → App passwords.
# Do NOT use your login password, especially on SSO/SAML instances where
# app passwords are the only way to bypass the IdP for API access.
NC_APP_PASSWORD=xxxxx-xxxxx-xxxxx-xxxxx
